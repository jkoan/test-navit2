msgid "Running from source directory\n"
msgstr ""

#. libc of navit returns "dummy"
msgid "Error getting current path. use ./ \n"
msgstr ""

#, c-format
msgid "setting '%s' to '%s'\n"
msgstr ""

msgid "first"
msgstr "మొదటి"

msgid "second"
msgstr "క్షణం"

msgid "sixth"
msgstr ""

msgid "third exit"
msgstr ""

#, c-format
msgid "%d feet"
msgstr ""

#, c-format
msgid "one mile"
msgid_plural "%d miles"
msgstr[0] ""
msgstr[1] ""

#, c-format
msgid "in one mile"
msgid_plural "in %d miles"
msgstr[0] ""
msgstr[1] ""

#, c-format
msgid "%d meters"
msgstr "%d మీటర్లు"

#, c-format
msgid "in %d.%d kilometers"
msgstr "%d లో. %d కిలోమీటర్లు"

#, c-format
msgid "one kilometer"
msgid_plural "%d kilometers"
msgstr[0] "ఒక కిలోమీటరు"
msgstr[1] "%d కిలోమీటర్లు"

#, c-format
msgid "in one kilometer"
msgid_plural "in %d kilometers"
msgstr[0] ""
msgstr[1] ""

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name. Feminine form. The stuff after | doesn't have to be included
#, c-format
msgid "%1$sonto %2$s|feminine form"
msgstr ""

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name. Neuter form. The stuff after | doesn't have to be included
#, c-format
msgid "%1$sonto %2$s|neuter form"
msgstr ""

msgid "onto the motorway ramp"
msgstr ""

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name 3: Separator (Space if required), 4: Systematic Street Name. Masculine form. The stuff after | doesn't have to be included
#, c-format
msgid "%sinto %s%s%s|masculine form"
msgstr ""

msgid "When possible, please turn around"
msgstr ""

#. TRANSLATORS: %s is the distance to the roundabout
#, c-format
msgid "Enter the roundabout %s"
msgstr ""

msgid "soon"
msgstr "త్వరలో"

msgid "now"
msgstr "ఇప్పుడు"

#. TRANSLATORS: the arg. is the phrase 'onto ...'. Left merge, the stuff after | doesn't have to be included.
#, c-format
msgid "then merge%1$s|left"
msgstr ""

#. TRANSLATORS: the first arg. is exit ref and/or name, the second is the direction of exit and the third is distance
#, c-format
msgid "Take exit %1$s %2$s %3$s"
msgstr ""

#. TRANSLATORS: the arg. is where to do the maneuver
#, c-format
msgid "then continue straight%1$s"
msgstr ""

#. TRANSLATORS: the arg. is where to do the maneuver
#, c-format
msgid "then keep left%1$s"
msgstr ""

#. TRANSLATORS: "right" as in "turn right"
msgid "right"
msgstr "కుడి"

#. TRANSLATORS: "left" as in "turn left"
msgid "left"
msgstr "ఎడమ"

#. TRANSLATORS: as in "turn easily right"
msgid "easily "
msgstr "తేలికగా "

#. TRANSLATORS: the first arg. is strength, the second is direction, the third is distance, the fourth is destination
#, c-format
msgid "Turn %1$s%2$s %3$s%4$s"
msgstr ""

#. TRANSLATORS: the arg. is distance. Right U-turn, the stuff after | doesn't have to be included.
#, c-format
msgid "Make a U-turn %1$s|right"
msgstr ""

#. TRANSLATORS: the arg. is distance
#, c-format
msgid "You have reached your destination %s"
msgstr "మీరు మీ గమ్యస్థానం %s చేరారు"

